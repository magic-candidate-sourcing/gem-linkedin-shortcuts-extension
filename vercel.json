{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/[[...route]].js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/privacy",
      "destination": "/api/privacy"
    }
  ]
}
