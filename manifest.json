{
  "manifest_version": 3,
  "name": "Gem LinkedIn Shortcuts",
  "version": "0.2.3",
  "description": "Run Gem and Ashby recruiting actions from LinkedIn, Gem, GitHub, and Gmail threads.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "https://gem-linkedin-shortcuts-extension.vercel.app/*",
    "https://www.linkedin.com/*",
    "https://www.gem.com/*",
    "https://app.gem.com/*",
    "https://mail.google.com/*",
    "https://gmail.googleapis.com/*",
    "https://github.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  },
  "action": {
    "default_title": "Gem LinkedIn Shortcuts",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "32": "src/icons/icon-32.png"
    }
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://www.linkedin.com/pub/*",
        "https://www.linkedin.com/talent/profile/*",
        "https://www.linkedin.com/talent/*/profile/*"
      ],
      "exclude_matches": [
        "https://reflect.app/*"
      ],
      "js": [
        "src/shared.js",
        "src/content_bootstrap.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.gem.com/candidate/*",
        "https://app.gem.com/candidate/*",
        "https://www.gem.com/projects/*",
        "https://app.gem.com/projects/*",
        "https://mail.google.com/mail/*",
        "https://github.com/*"
      ],
      "exclude_matches": [
        "https://reflect.app/*"
      ],
      "js": [
        "src/shared.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.gem.com/candidate/*",
        "https://app.gem.com/candidate/*"
      ],
      "js": [
        "src/gem_content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
